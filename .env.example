# ==============================================================================
# AI Cyber Security Suite — Environment Variables
# Copy this file to .env and configure it for your local or production setup.
# ==============================================================================

# ── Backend (FastAPI) ─────────────────────────────────────────────────────────
PROJECT_NAME="AI Cyber Security Suite API"
VERSION="1.0.0"
ENVIRONMENT="development" # Set to "production" in production environments

# ── Security ──────────────────────────────────────────────────────────────────
# CRITICAL: Must be a long, random secret key for JWT signing.
# Generate one with: openssl rand -hex 32
SECRET_KEY="changeme-production-secret-must-be-very-long"
ACCESS_TOKEN_EXPIRE_MINUTES=1440 # 24 hours

# ── Database ──────────────────────────────────────────────────────────────────
# The database URL for SQLAlchemy.
# Default uses local async SQLite. 
# For PostgreSQL in Docker: "postgresql+asyncpg://postgres:postgres@db/cybersec"
DATABASE_URL="sqlite+aiosqlite:///./backend.db"

# ── Redis Cache (Optional) ────────────────────────────────────────────────────
# Redis is used for advanced distributed rate-limiting and caching if configured.
# REDIS_URL="redis://localhost:6379/0"
# CACHE_TTL_SECONDS=3600

# ── Frontend (Vite) ───────────────────────────────────────────────────────────
# Variables prefixed with VITE_ are exposed to the frontend browser code.
VITE_API_URL="http://localhost:8000"

# ── Extension ─────────────────────────────────────────────────────────────────
# The extension currently falls back to http://localhost:8000 by default.
# Ensure your production API_URL is built into the extension.
