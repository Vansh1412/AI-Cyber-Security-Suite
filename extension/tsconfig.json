{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": ["background/**/*.ts", "popup/**/*.ts", "content/**/*.ts", "services/**/*.ts", "utils/**/*.ts", "types/**/*.ts"]
}
