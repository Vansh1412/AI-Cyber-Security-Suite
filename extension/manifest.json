{
  "manifest_version": 3,
  "name": "AI Cyber Security Suite",
  "version": "1.0.0",
  "description": "Real-time AI-powered URL threat detection. Powered by XGBoost + SHAP.",
  "icons": {
    "16":  "assets/icon16.png",
    "32":  "assets/icon32.png",
    "48":  "assets/icon48.png",
    "128": "assets/icon128.png"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "AI Cyber Security Suite",
    "default_icon": {
      "16":  "assets/icon16.png",
      "32":  "assets/icon32.png",
      "48":  "assets/icon48.png",
      "128": "assets/icon128.png"
    }
  },
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content/content.js"],
      "run_at": "document_idle"
    }
  ],
  "permissions": [
    "activeTab",
    "tabs",
    "storage",
    "scripting",
    "notifications",
    "contextMenus",
    "alarms"
  ],
  "host_permissions": [
    "http://localhost:8000/*",
    "http://127.0.0.1:8000/*",
    "https://*.cybersecai.com/*"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },
  "web_accessible_resources": [
    {
      "resources": ["assets/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
